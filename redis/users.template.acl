user default on >{{REDIS_ROOT_PASSWORD}} ~* &* +@all

user auth_service on >{{REDIS_AUTH_SERVICE_PASSWORD}} ~* &* +@read +@write -@dangerous -@admin -@scripting -DEBUG -FLUSHALL -FLUSHDB

user parser_service on >{{REDIS_PARSER_SERVICE_PASSWORD}} ~* &* +@read +@write -@dangerous -@admin -@scripting -DEBUG -FLUSHALL -FLUSHDB